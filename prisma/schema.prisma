generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  avatarUrl     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  settings             UserSettings?
  agentConfigs         AgentConfig[]
  icpConfig            ICPConfig?
  leads                Lead[]
  generatedPosts       GeneratedPost[]
  generatedMessages    GeneratedMessage[]
  generatedComments    GeneratedComment[]
  marketBriefings      MarketBriefing[]
  nurturingActions     NurturingAction[]
  performanceInsights  PerformanceInsight[]
  connectionRequests   ConnectionRequest[]
  linkedInAuth         LinkedInAuth?
  linkedInPosts        LinkedInPost[]
  scheduledPosts       ScheduledPost[]
  metrics              Metrics?
  activityLogs         ActivityLog[]
  apiMetrics           ApiMetric[]
  complianceLogs       ComplianceLog[]
  messageTemplates     MessageTemplate[]
  experiments          Experiment[]
  experimentResults    ExperimentResult[]
  feedbackEvents       FeedbackEvent[]
  contentMetrics       ContentMetric[]
  contacts             Contact[]
  deals                Deal[]
  emailSequences       EmailSequence[]
  emailMessages        EmailMessage[]
  pipelineStages       PipelineStage[]
  workflows            Workflow[]
  workflowExecutions   WorkflowExecution[]
  notifications        Notification[]
  notificationPreferences NotificationPreference[]
  webhooks             Webhook[]
  webhookDeliveries    WebhookDelivery[]
  orchestratorState    OrchestratorState?
  complianceState      ComplianceState?
  feedbackRules        FeedbackRule[]
  eventHistory         EventHistory[]
}

model UserSettings {
  userId            String   @id
  provider          String   @default("groq")
  model             String   @default("llama-3.3-70b-versatile")
  providerApiKeys   String   @default("{}")
  channels          String   @default("[]")
  allowShell        Boolean  @default(true)
  allowBrowser      Boolean  @default(true)
  forbiddenCommands String   @default("[]")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AgentConfig {
  id           String    @id @default(cuid())
  userId       String
  agentId      String
  name         String
  num          String
  status       String    @default("setup")
  role         String
  skillMd      String
  heartbeatMd  String
  lastRunAt    DateTime?
  runsToday    Int       @default(0)
  nextRunLabel String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, agentId])
}

model ICPConfig {
  id           String  @id @default(cuid())
  userId       String  @unique
  titles       String  @default("[]")
  sectors      String  @default("[]")
  companySizes String  @default("[]")
  minScore     Int     @default(60)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Lead {
  id            String   @id @default(cuid())
  userId        String
  prenom        String
  poste         String   @default("")
  entreprise    String
  secteur       String   @default("")
  score         Int      @default(0)
  action        String   @default("viewed")
  postSujet     String   @default("")
  statut        String   @default("new")
  dateCollected String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, statut])
  @@index([userId, score])
}

model GeneratedPost {
  id        String   @id @default(cuid())
  userId    String
  text      String
  topic     String   @default("")
  model     String   @default("")
  agentRun  Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model GeneratedMessage {
  id              String   @id @default(cuid())
  userId          String
  leadId          String   @default("")
  leadName        String   @default("")
  leadEntreprise  String   @default("")
  content         String
  timing          String   @default("")
  model           String   @default("")
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, leadId])
}

model GeneratedComment {
  id           String   @id @default(cuid())
  userId       String
  authorName   String   @default("")
  authorPoste  String   @default("")
  postExcerpt  String   @default("")
  comment      String
  model        String   @default("")
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model MarketBriefing {
  id            String   @id @default(cuid())
  userId        String
  title         String
  summary       String   @default("")
  trends        String   @default("[]")
  opportunities String   @default("[]")
  competitors   String   @default("[]")
  model         String   @default("")
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NurturingAction {
  id             String   @id @default(cuid())
  userId         String
  leadId         String   @default("")
  leadName       String   @default("")
  leadEntreprise String   @default("")
  type           String   @default("check-in")
  content        String
  model          String   @default("")
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PerformanceInsight {
  id             String   @id @default(cuid())
  userId         String
  category       String
  metric         String
  value          String
  recommendation String
  priority       String   @default("medium")
  model          String   @default("")
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ConnectionRequest {
  id                 String   @id @default(cuid())
  userId             String
  prospectName       String
  prospectPoste      String   @default("")
  prospectEntreprise String   @default("")
  note               String   @default("")
  status             String   @default("pending")
  model              String   @default("")
  createdAt          DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LinkedInAuth {
  id               String    @id @default(cuid())
  userId           String    @unique
  accessToken      String    @default("")
  tokenExpiresAt   DateTime?
  linkedInUserId   String    @default("")
  firstName        String    @default("")
  lastName         String    @default("")
  headline         String?
  profilePictureUrl String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LinkedInPost {
  id         String   @id @default(cuid())
  userId     String
  text       String
  visibility String   @default("PUBLIC")
  likes      Int      @default(0)
  comments   Int      @default(0)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ScheduledPost {
  id          String    @id @default(cuid())
  userId      String
  text        String
  visibility  String    @default("PUBLIC")
  scheduledAt DateTime
  status      String    @default("scheduled")
  publishedAt DateTime?
  error       String?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Metrics {
  id              String   @id @default(cuid())
  userId          String   @unique
  postsPublished  Int      @default(0)
  impressionsMoy  Int      @default(0)
  tauxEngagement  Float    @default(0)
  profilsCollectes Int     @default(0)
  leadsQualifies  Int      @default(0)
  messagesEnvoyes Int      @default(0)
  tauxReponse     Float    @default(0)
  rdvsGeneres     Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  agentId   String   @default("")
  agentName String   @default("")
  type      String   @default("info")
  message   String
  details   String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, agentId])
  @@index([userId, createdAt])
}

model ApiMetric {
  id          String   @id @default(cuid())
  userId      String
  endpoint    String
  method      String   @default("GET")
  statusCode  Int      @default(200)
  durationMs  Int      @default(0)
  calledAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, calledAt])
}

model ComplianceLog {
  id        String   @id @default(cuid())
  userId    String
  type      String   @default("info")
  category  String
  message   String
  value     Int      @default(0)
  limit     Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, category])
  @@index([userId, createdAt])
}

model MessageTemplate {
  id        String   @id @default(cuid())
  userId    String
  name      String
  timing    String   @default("")
  content   String
  notes     String   @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Experiment {
  id            String    @id @default(cuid())
  userId        String
  name          String
  description   String    @default("")
  type          String    @default("ab")
  status        String    @default("draft")
  targetAgentId String?
  variants      String    @default("[]")
  trafficSplit  String    @default("50/50")
  startDate     DateTime?
  endDate       DateTime?
  results       String?
  winnerId      String?
  confidence    Float     @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, targetAgentId])
}

model ExperimentResult {
  id           String   @id @default(cuid())
  userId       String
  experimentId String
  variantId    String
  variantName  String   @default("")
  impressionId String?
  outcome      String   @default("")
  metricValue  Float    @default(0)
  metadata     String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, experimentId])
  @@index([userId, variantId])
  @@index([userId, outcome])
}

model FeedbackEvent {
  id            String   @id @default(cuid())
  userId        String
  sourceAgentId String
  contentType   String
  contentId     String   @default("")
  metricType    String
  metricValue   Float    @default(0)
  baselineValue Float    @default(0)
  improvement   Float    @default(0)
  actionTaken   String?
  lesson        String?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sourceAgentId])
  @@index([userId, contentType])
  @@index([userId, createdAt])
}

model ContentMetric {
  id             String   @id @default(cuid())
  userId         String
  contentType    String
  contentId      String
  agentId        String   @default("")
  impressions    Int      @default(0)
  likes          Int      @default(0)
  comments       Int      @default(0)
  shares         Int      @default(0)
  clicks         Int      @default(0)
  replies        Int      @default(0)
  conversions    Int      @default(0)
  engagementRate Float    @default(0)
  experimentId   String?
  variantId      String?
  period         String   @default("")
  recordedAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, contentType])
  @@index([userId, agentId])
  @@index([userId, recordedAt])
  @@unique([userId, contentId, period])
}

model Contact {
  id          String    @id @default(cuid())
  userId      String
  prenom      String
  nom         String    @default("")
  email       String    @default("")
  telephone   String?
  entreprise  String    @default("")
  poste       String    @default("")
  secteur     String    @default("")
  siteWeb     String?
  linkedinUrl String?
  source      String    @default("manual")
  notes       String?
  tags        String    @default("[]")
  score       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, email])
  @@index([userId, entreprise])
}

model Deal {
  id                String    @id @default(cuid())
  userId            String
  contactId         String
  titre             String
  valeur            Float     @default(0)
  devise            String    @default("EUR")
  stage             String    @default("prospect")
  probabilite       Int       @default(20)
  dateCloturePrevue DateTime?
  sourceCanal       String?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, stage])
  @@index([userId, contactId])
}

model EmailSequence {
  id           String    @id @default(cuid())
  userId       String
  name         String
  description  String    @default("")
  triggerEvent String    @default("manual")
  status       String    @default("draft")
  steps        String    @default("[]")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model EmailMessage {
  id         String    @id @default(cuid())
  userId     String
  contactId  String
  sequenceId String?
  subject    String
  body       String
  status     String    @default("draft")
  sentAt     DateTime?
  openedAt   DateTime?
  clickedAt  DateTime?
  repliedAt  DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, contactId])
  @@index([userId, sequenceId])
  @@index([userId, status])
}

model PipelineStage {
  id        String   @id @default(cuid())
  userId    String
  name      String
  order     Int      @default(0)
  color     String   @default("#00D4FF")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, order])
}

// ─── Workflow persistence ────────────────────────────────────────────

model Workflow {
  id              String    @id @default(cuid())
  userId          String
  name            String
  description     String    @default("")
  status          String    @default("draft")  // draft | active | paused | archived
  nodes           String    @default("[]")      // JSON
  edges           String    @default("[]")      // JSON
  tags            String    @default("[]")      // JSON
  version         Int       @default(1)
  lastExecutionAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  executions  WorkflowExecution[]

  @@index([userId, status])
}

model WorkflowExecution {
  id           String   @id @default(cuid())
  userId       String
  workflowId   String
  status       String   @default("running")  // running | completed | failed
  triggerNode  String   @default("")
  currentNode  String?
  error        String?
  data         String   @default("{}")       // JSON
  steps        String   @default("[]")       // JSON
  startedAt    DateTime @default(now())
  completedAt  DateTime?

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, workflowId])
  @@index([userId, startedAt])
}

// ─── Notification persistence ────────────────────────────────────────

model Notification {
  id             String    @id @default(cuid())
  userId         String
  title          String
  message        String
  category       String    @default("system")  // agent | lead | deal | email | linkedin | compliance | workflow | system
  priority       String    @default("medium")  // low | medium | high | critical
  actionUrl      String?
  actionLabel    String?
  sourceAgent    String?
  sourceWorkflow String?
  metadata       String?                        // JSON
  read           Boolean   @default(false)
  readAt         DateTime?
  dismissed      Boolean   @default(false)
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, category])
  @@index([userId, dismissed])
  @@index([userId, createdAt])
}

model NotificationPreference {
  id                String   @id @default(cuid())
  userId            String
  category          String   @unique  // one preference row per category per user
  enabled           Boolean  @default(true)
  minPriority       String   @default("low")  // low | medium | high | critical
  quietHoursEnabled Boolean  @default(false)
  quietHoursStart   String   @default("")  // "22:00"
  quietHoursEnd     String   @default("")  // "08:00"
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Webhook persistence ─────────────────────────────────────────────

model Webhook {
  id                String   @id @default(cuid())
  userId            String
  name              String
  provider          String   @default("custom")  // slack | discord | zapier | make | custom
  url               String
  secret            String?
  events            String   @default("[]")       // JSON array of event strings
  status            String   @default("active")   // active | paused | error
  headers           String?                        // JSON
  retryCount        Int      @default(3)
  retryDelayMs      Int      @default(5000)
  timeoutMs         Int      @default(10000)
  lastTriggeredAt   DateTime?
  lastStatus        Int?
  errorCount        Int      @default(0)
  totalDeliveries   Int      @default(0)
  successDeliveries Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries  WebhookDelivery[]

  @@index([userId, status])
}

model WebhookDelivery {
  id          String    @id @default(cuid())
  userId      String
  webhookId   String
  event       String
  status      String    @default("pending")  // pending | delivered | failed | retrying
  attempts    Int       @default(0)
  request     String    @default("{}")       // JSON
  response    String?                         // JSON
  deliveredAt DateTime?
  nextRetryAt DateTime?
  error       String?
  createdAt   DateTime  @default(now())

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, webhookId])
  @@index([userId, createdAt])
}

// ─── Orchestrator state persistence ──────────────────────────────────

model OrchestratorState {
  id        String   @id @default(cuid())
  userId    String   @unique
  state     String   @default("stopped")  // running | stopped | paused
  rules     String   @default("[]")       // JSON (serialized HeartbeatRule[])
  startedAt DateTime?
  metrics   String   @default("{}")       // JSON
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Compliance state persistence ────────────────────────────────────

model ComplianceState {
  id                String   @id @default(cuid())
  userId            String   @unique
  level             String   @default("moderate")  // conservative | moderate | aggressive
  warmupActive      Boolean  @default(false)
  warmupStartDate   DateTime?
  usage             String   @default("{}")         // JSON Record<LinkedInAction, number>
  weeklyInvitations Int      @default(0)
  lastResetDate     String   @default("")
  lastWeeklyReset   String   @default("")
  violations        String   @default("[]")         // JSON
  mimicryConfig     String   @default("{}")         // JSON
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Feedback rule persistence ───────────────────────────────────────

model FeedbackRule {
  id         String   @id @default(cuid())
  userId     String
  ruleId     String   // logical ID like "low-engagement"
  name       String
  metricType String
  condition  String   // below | above | equals
  threshold  Float    @default(0)
  action     String   @default("none")
  message    String   @default("")
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ruleId])
}

// ─── Event history persistence ───────────────────────────────────────

model EventHistory {
  id        String   @id @default(cuid())
  userId    String
  eventType String
  agentId   String   @default("")
  agentName String   @default("")
  data      String?                     // JSON
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, eventType])
  @@index([userId, createdAt])
}
