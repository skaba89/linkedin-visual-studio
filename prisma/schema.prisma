generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  avatarUrl     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  settings             UserSettings?
  agentConfigs         AgentConfig[]
  icpConfig            ICPConfig?
  leads                Lead[]
  generatedPosts       GeneratedPost[]
  generatedMessages    GeneratedMessage[]
  generatedComments    GeneratedComment[]
  marketBriefings      MarketBriefing[]
  nurturingActions     NurturingAction[]
  performanceInsights  PerformanceInsight[]
  connectionRequests   ConnectionRequest[]
  linkedInAuth         LinkedInAuth?
  linkedInPosts        LinkedInPost[]
  scheduledPosts       ScheduledPost[]
  metrics              Metrics?
  activityLogs         ActivityLog[]
  apiMetrics           ApiMetric[]
  complianceLogs       ComplianceLog[]
  messageTemplates     MessageTemplate[]
  experiments          Experiment[]
  experimentResults    ExperimentResult[]
  feedbackEvents       FeedbackEvent[]
  contentMetrics       ContentMetric[]
  contacts             Contact[]
  deals                Deal[]
  emailSequences       EmailSequence[]
  emailMessages        EmailMessage[]
  pipelineStages       PipelineStage[]
}

model UserSettings {
  userId            String   @id
  provider          String   @default("groq")
  model             String   @default("llama-3.3-70b-versatile")
  providerApiKeys   String   @default("{}")
  channels          String   @default("[]")
  allowShell        Boolean  @default(true)
  allowBrowser      Boolean  @default(true)
  forbiddenCommands String   @default("[]")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AgentConfig {
  id           String    @id @default(cuid())
  userId       String
  agentId      String
  name         String
  num          String
  status       String    @default("setup")
  role         String
  skillMd      String
  heartbeatMd  String
  lastRunAt    DateTime?
  runsToday    Int       @default(0)
  nextRunLabel String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, agentId])
}

model ICPConfig {
  id           String  @id @default(cuid())
  userId       String  @unique
  titles       String  @default("[]")
  sectors      String  @default("[]")
  companySizes String  @default("[]")
  minScore     Int     @default(60)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Lead {
  id            String   @id @default(cuid())
  userId        String
  prenom        String
  poste         String   @default("")
  entreprise    String
  secteur       String   @default("")
  score         Int      @default(0)
  action        String   @default("viewed")
  postSujet     String   @default("")
  statut        String   @default("new")
  dateCollected String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, statut])
  @@index([userId, score])
}

model GeneratedPost {
  id        String   @id @default(cuid())
  userId    String
  text      String
  topic     String   @default("")
  model     String   @default("")
  agentRun  Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model GeneratedMessage {
  id              String   @id @default(cuid())
  userId          String
  leadId          String   @default("")
  leadName        String   @default("")
  leadEntreprise  String   @default("")
  content         String
  timing          String   @default("")
  model           String   @default("")
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, leadId])
}

model GeneratedComment {
  id           String   @id @default(cuid())
  userId       String
  authorName   String   @default("")
  authorPoste  String   @default("")
  postExcerpt  String   @default("")
  comment      String
  model        String   @default("")
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model MarketBriefing {
  id            String   @id @default(cuid())
  userId        String
  title         String
  summary       String   @default("")
  trends        String   @default("[]")
  opportunities String   @default("[]")
  competitors   String   @default("[]")
  model         String   @default("")
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NurturingAction {
  id             String   @id @default(cuid())
  userId         String
  leadId         String   @default("")
  leadName       String   @default("")
  leadEntreprise String   @default("")
  type           String   @default("check-in")
  content        String
  model          String   @default("")
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PerformanceInsight {
  id             String   @id @default(cuid())
  userId         String
  category       String
  metric         String
  value          String
  recommendation String
  priority       String   @default("medium")
  model          String   @default("")
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ConnectionRequest {
  id                 String   @id @default(cuid())
  userId             String
  prospectName       String
  prospectPoste      String   @default("")
  prospectEntreprise String   @default("")
  note               String   @default("")
  status             String   @default("pending")
  model              String   @default("")
  createdAt          DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LinkedInAuth {
  id               String    @id @default(cuid())
  userId           String    @unique
  accessToken      String    @default("")
  tokenExpiresAt   DateTime?
  linkedInUserId   String    @default("")
  firstName        String    @default("")
  lastName         String    @default("")
  headline         String?
  profilePictureUrl String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LinkedInPost {
  id         String   @id @default(cuid())
  userId     String
  text       String
  visibility String   @default("PUBLIC")
  likes      Int      @default(0)
  comments   Int      @default(0)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ScheduledPost {
  id          String    @id @default(cuid())
  userId      String
  text        String
  visibility  String    @default("PUBLIC")
  scheduledAt DateTime
  status      String    @default("scheduled")
  publishedAt DateTime?
  error       String?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Metrics {
  id              String   @id @default(cuid())
  userId          String   @unique
  postsPublished  Int      @default(0)
  impressionsMoy  Int      @default(0)
  tauxEngagement  Float    @default(0)
  profilsCollectes Int     @default(0)
  leadsQualifies  Int      @default(0)
  messagesEnvoyes Int      @default(0)
  tauxReponse     Float    @default(0)
  rdvsGeneres     Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  agentId   String   @default("")
  agentName String   @default("")
  type      String   @default("info")
  message   String
  details   String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, agentId])
  @@index([userId, createdAt])
}

model ApiMetric {
  id          String   @id @default(cuid())
  userId      String
  endpoint    String
  method      String   @default("GET")
  statusCode  Int      @default(200)
  durationMs  Int      @default(0)
  calledAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, calledAt])
}

model ComplianceLog {
  id        String   @id @default(cuid())
  userId    String
  type      String   @default("info")
  category  String
  message   String
  value     Int      @default(0)
  limit     Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, category])
  @@index([userId, createdAt])
}

model MessageTemplate {
  id        String   @id @default(cuid())
  userId    String
  name      String
  timing    String   @default("")
  content   String
  notes     String   @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Experiment {
  id            String    @id @default(cuid())
  userId        String
  name          String
  description   String    @default("")
  type          String    @default("ab")
  status        String    @default("draft")
  targetAgentId String?
  variants      String    @default("[]")
  trafficSplit  String    @default("50/50")
  startDate     DateTime?
  endDate       DateTime?
  results       String?
  winnerId      String?
  confidence    Float     @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, targetAgentId])
}

model ExperimentResult {
  id           String   @id @default(cuid())
  userId       String
  experimentId String
  variantId    String
  variantName  String   @default("")
  impressionId String?
  outcome      String   @default("")
  metricValue  Float    @default(0)
  metadata     String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, experimentId])
  @@index([userId, variantId])
  @@index([userId, outcome])
}

model FeedbackEvent {
  id            String   @id @default(cuid())
  userId        String
  sourceAgentId String
  contentType   String
  contentId     String   @default("")
  metricType    String
  metricValue   Float    @default(0)
  baselineValue Float    @default(0)
  improvement   Float    @default(0)
  actionTaken   String?
  lesson        String?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sourceAgentId])
  @@index([userId, contentType])
  @@index([userId, createdAt])
}

model ContentMetric {
  id             String   @id @default(cuid())
  userId         String
  contentType    String
  contentId      String
  agentId        String   @default("")
  impressions    Int      @default(0)
  likes          Int      @default(0)
  comments       Int      @default(0)
  shares         Int      @default(0)
  clicks         Int      @default(0)
  replies        Int      @default(0)
  conversions    Int      @default(0)
  engagementRate Float    @default(0)
  experimentId   String?
  variantId      String?
  period         String   @default("")
  recordedAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, contentType])
  @@index([userId, agentId])
  @@index([userId, recordedAt])
  @@unique([userId, contentId, period])
}

model Contact {
  id          String    @id @default(cuid())
  userId      String
  prenom      String
  nom         String    @default("")
  email       String    @default("")
  telephone   String?
  entreprise  String    @default("")
  poste       String    @default("")
  secteur     String    @default("")
  siteWeb     String?
  linkedinUrl String?
  source      String    @default("manual")
  notes       String?
  tags        String    @default("[]")
  score       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, email])
  @@index([userId, entreprise])
}

model Deal {
  id                String    @id @default(cuid())
  userId            String
  contactId         String
  titre             String
  valeur            Float     @default(0)
  devise            String    @default("EUR")
  stage             String    @default("prospect")
  probabilite       Int       @default(20)
  dateCloturePrevue DateTime?
  sourceCanal       String?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, stage])
  @@index([userId, contactId])
}

model EmailSequence {
  id           String    @id @default(cuid())
  userId       String
  name         String
  description  String    @default("")
  triggerEvent String    @default("manual")
  status       String    @default("draft")
  steps        String    @default("[]")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model EmailMessage {
  id         String    @id @default(cuid())
  userId     String
  contactId  String
  sequenceId String?
  subject    String
  body       String
  status     String    @default("draft")
  sentAt     DateTime?
  openedAt   DateTime?
  clickedAt  DateTime?
  repliedAt  DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, contactId])
  @@index([userId, sequenceId])
  @@index([userId, status])
}

model PipelineStage {
  id        String   @id @default(cuid())
  userId    String
  name      String
  order     Int      @default(0)
  color     String   @default("#00D4FF")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, order])
}
